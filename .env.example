###
# Docker Environment
##
COMPOSE_PROJECT_NAME=my-project
DOCKER_PHP_SERVICE=php
DOCKER_DB_SERVICE=db
DOCKER_WEB_SERVER_SERVICE=nginx

###
# App User (optional - run commands as this user in containers)
##
# APP_USER=www-data

###
# MySQL
##
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=myproject
MYSQL_USER=myproject
MYSQL_PASSWORD=password
MYSQL_HOST=db

###
# Magento (optional - only needed for magento install command)
##
# MAGENTO_ADMIN_USERNAME=admin
# MAGENTO_ADMIN_PASSWORD=admin123
# MAGENTO_ADMIN_EMAIL=admin@example.com
# MAGENTO_ADMIN_FIRSTNAME=Admin
# MAGENTO_ADMIN_LASTNAME=User
# OPENSEARCH_HOST=opensearch
